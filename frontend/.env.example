# The API Gateway base URL output by `serverless deploy`
# dev:  https://<id>.execute-api.ap-southeast-1.amazonaws.com/dev
# prod: https://<id>.execute-api.ap-southeast-1.amazonaws.com/prod
VITE_API_BASE_URL=https://<api-id>.execute-api.ap-southeast-1.amazonaws.com/dev

# Backend environment variables (set in Amplify as plain env vars, not VITE_ prefixed)
# used by the Serverless deploy phase, not Vite
SENDER_EMAIL=goornot.5224@gmail.com
APP_BASE_URL=https://main.<amplify-app-id>.amplifyapp.com
GOOGLE_MAPS_API_KEY=
