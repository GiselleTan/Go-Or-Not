{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Weather2HRQuery",
  "type": "object",
  "properties": {
    "latitude": {
      "type": "string",
      "pattern": "^-?([0-9]|[1-8][0-9]|90)(\\.[0-9]+)?$"
    },
    "longitude": {
      "type": "string",
      "pattern": "^-?([0-9]|[1-9][0-9]|1[0-7][0-9]|180)(\\.[0-9]+)?$"
    }
  },
  "required": ["latitude", "longitude"]
}
