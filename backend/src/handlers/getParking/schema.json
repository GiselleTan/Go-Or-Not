{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "ParkingQuery",
  "type": "object",
  "properties": {
    "latitude": {
      "type": "string",
      "pattern": "^-?([0-9]|[1-8][0-9])(\\.[0-9]+)?$"
    },
    "longitude": {
      "type": "string",
      "pattern": "^-?([0-9]|[1-9][0-9]|1[0-7][0-9])(\\.[0-9]+)?$"
    },
    "radiusKm": {
      "type": "string",
      "pattern": "^(0\\.[1-9]|[1-9](\\.[0-9]+)?)$",
      "description": "Search radius in km (e.g., 0.1 to 10.0)"
    }
  },
  "required": ["latitude", "longitude"]
}
